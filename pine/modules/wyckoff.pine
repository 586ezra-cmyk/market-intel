// ============================================================
// Wyckoff Phases — Accumulation & Distribution
// Pine Script v6 · מערכת מסחר חכמה
// ============================================================
//@version=6
indicator("Wyckoff Phases", overlay=true, max_bars_back=500)

secret    = input.string("dev-secret", "Webhook Secret")
volFilter = input.bool(true, "Require low volume on Spring/UT")
lb        = input.int(20, "Range lookback (bars)")

// ─── Volume helpers ───────────────────────────────────────────────────────────
volMA   = ta.sma(volume, 20)
lowVol  = volume < volMA * 0.7
highVol = volume > volMA * 1.3

// ─── Trading range boundaries ─────────────────────────────────────────────────
rangeHigh = ta.highest(high, lb)[1]
rangeLow  = ta.lowest(low,  lb)[1]

// ─── ACCUMULATION events ─────────────────────────────────────────────────────
// Phase C — Spring: wick below range low, bullish close back inside, low volume
spring = low < rangeLow and close > rangeLow and close > open and
         (not volFilter or lowVol)

// Phase D — LPS (Last Point of Support): pullback to range mid that holds
lps = close > rangeLow and close < (rangeHigh + rangeLow) / 2 and
      close > open and low > rangeLow[1] and highVol

// Phase D — SOS (Sign of Strength): strong bull break of range top
sos = ta.crossover(close, rangeHigh) and highVol

// ─── DISTRIBUTION events ──────────────────────────────────────────────────────
// Phase C — Upthrust After Distribution (UTAD): wick above range high, bearish close back, low vol
utad = high > rangeHigh and close < rangeHigh and close < open and
       (not volFilter or lowVol)

// Phase D — LPSY (Last Point of Supply): weak rally near range top
lpsy = close < rangeHigh and close > (rangeHigh + rangeLow) / 2 and
       close < open and high < rangeHigh[1] and highVol

// Phase D — SOW (Sign of Weakness): strong bear break of range bottom
sow = ta.crossunder(close, rangeLow) and highVol

// ─── Visuals ──────────────────────────────────────────────────────────────────
plotshape(spring,   title="Spring",  location=location.belowbar, style=shape.labelup,
          color=color.new(color.green, 20),  textcolor=color.white, text="🌱 Spring",  size=size.small)
plotshape(lps,      title="LPS",     location=location.belowbar, style=shape.labelup,
          color=color.new(color.teal, 30),   textcolor=color.white, text="LPS",         size=size.tiny)
plotshape(sos,      title="SOS",     location=location.abovebar, style=shape.labeldown,
          color=color.new(color.aqua, 20),   textcolor=color.black, text="SOS ✅",      size=size.small)
plotshape(utad,     title="UTAD/UT", location=location.abovebar, style=shape.labeldown,
          color=color.new(color.red,  20),   textcolor=color.white, text="⬆ UTAD",      size=size.small)
plotshape(lpsy,     title="LPSY",    location=location.abovebar, style=shape.labeldown,
          color=color.new(color.orange, 30), textcolor=color.white, text="LPSY",         size=size.tiny)
plotshape(sow,      title="SOW",     location=location.belowbar, style=shape.labelup,
          color=color.new(color.red,  30),   textcolor=color.white, text="SOW ⚠️",      size=size.small)

// Range box (last lb bars)
bgcolor(low >= rangeLow and high <= rangeHigh ?
        color.new(color.blue, 97) : na, title="Range background")

// ─── Alerts ───────────────────────────────────────────────────────────────────
accPayload  = '{"secret":"' + secret + '","event":"wyckoff","symbol":"' + syminfo.ticker +
              '","timeframe":"' + timeframe.period + '","time":' + str.tostring(math.round(time)) +
              ',"phase":"accumulation","confidence":0.75}'
distPayload = '{"secret":"' + secret + '","event":"wyckoff","symbol":"' + syminfo.ticker +
              '","timeframe":"' + timeframe.period + '","time":' + str.tostring(math.round(time)) +
              ',"phase":"distribution","confidence":0.75}'

alertcondition(spring, "Wyckoff — Spring (Acc. C)",     accPayload)
alertcondition(lps,    "Wyckoff — LPS (Acc. D)",        accPayload)
alertcondition(sos,    "Wyckoff — SOS (Acc. D)",        accPayload)
alertcondition(utad,   "Wyckoff — UTAD/UT (Dist. C)",   distPayload)
alertcondition(lpsy,   "Wyckoff — LPSY (Dist. D)",      distPayload)
alertcondition(sow,    "Wyckoff — SOW (Dist. D)",       distPayload)
