# ============================================================
# מערכת מסחר חכמה — ICT + Wyckoff
# Copy to apps/server/.env and fill in values
# ============================================================

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
WS_PORT=3002
NODE_ENV=development

# ─── Security ────────────────────────────────────────────────────────────────
# Must match the "secret" input in every Pine Script indicator
TV_SECRET=your-secure-secret-here
# Legacy alias (used in some server files)
TV_WEBHOOK_SECRET=your-secure-secret-here

# ─── Database ────────────────────────────────────────────────────────────────
DB_PATH=./data/market.db

# ─── Telegram ────────────────────────────────────────────────────────────────
# Create bot via @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Supergroup chat ID (negative number, e.g. -1001234567890)
# Add @getmyid_bot to group to find it
TELEGRAM_CHAT_ID=-1001234567890

# Message Thread IDs for each topic
# After creating topics, use GET /getUpdates to find message_thread_id values
TELEGRAM_TOPIC_DAILY=1
TELEGRAM_TOPIC_WEEKLY=2
TELEGRAM_TOPIC_HIGH=3
TELEGRAM_TOPIC_BRIEFING=4
TELEGRAM_TOPIC_CALENDAR=5

# ─── Economic Calendar ────────────────────────────────────────────────────────
# Primary: ForexFactory scraping (no key needed)
# Fallback: Financial Modeling Prep (free tier: 250 req/day)
FMP_API_KEY=your-fmp-api-key-here

# ─── Backup ───────────────────────────────────────────────────────────────────
BACKUP_DIR=./data/backups

# ─── Frontend (apps/web/.env.local) ──────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:3001
# NEXT_PUBLIC_WS_URL=ws://localhost:3002

# ─── TradingView Pine Script Setup ───────────────────────────────────────────
# 1. Set "Webhook Secret" input in each indicator = TV_SECRET value above
# 2. Alerts → Create Alert → Webhook URL: http://YOUR_IP:3001/webhook/tradingview
# 3. For ict_master.pine: one alert "Any alert() function call" covers everything
# 4. For local dev, use ngrok: ngrok http 3001 → use the https URL
